# === LLM Provider (pick ONE — see docs/litellm-setup.md) ===
# PanGu uses LiteLLM to support multiple LLM providers. Choose ONE provider
# below, fill in its credentials, then update config/settings.toml::[llm].provider
# to the matching identifier (e.g. "azure/$AZURE_DEPLOYMENT",
# "deepseek/deepseek-chat", "gemini/gemini-2.5-flash", "openai/gpt-4o", ...).

# --- Option A: Azure OpenAI (matches settings.toml default) ---
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_KEY=
AZURE_API_VERSION=2024-08-01-preview
AZURE_DEPLOYMENT=your-deployment-name

# --- Option B: DeepSeek ---
# DEEPSEEK_API_KEY=

# --- Option C: Google Gemini ---
# GEMINI_API_KEY=

# --- Option D: OpenAI ---
# OPENAI_API_KEY=

# === Feishu Bot (required — see docs/feishu-bot-setup.md) ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
